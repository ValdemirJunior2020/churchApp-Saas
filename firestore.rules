// File: firestore.rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasChurchId() {
      return userDocExists() &&
        currentUserDoc().data.churchId != null;
    }

    function belongsToChurch(churchId) {
      return isSignedIn() &&
        hasChurchId() &&
        currentUserDoc().data.churchId == churchId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        userDocExists() &&
        (
          currentUserDoc().data.role == "superadmin" ||
          currentUserDoc().data.role == "platformadmin" ||
          currentUserDoc().data.role == "SUPER_ADMIN" ||
          currentUserDoc().data.role == "SUPERADMIN"
        );
    }

    function isChurchOwner(churchId) {
      return isSignedIn() &&
        (
          get(/databases/$(database)/documents/churches/$(churchId)).data.ownerId == request.auth.uid ||
          get(/databases/$(database)/documents/churches/$(churchId)).data.pastorId == request.auth.uid ||
          get(/databases/$(database)/documents/churches/$(churchId)).data.createdBy == request.auth.uid ||
          isSuperAdmin()
        );
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if isOwnUser(userId);
      allow read: if isOwnUser(userId) || isSuperAdmin();
      allow update: if isOwnUser(userId) || isSuperAdmin();
      allow delete: if isOwnUser(userId) || isSuperAdmin();
    }

    match /churches/{churchId} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid;

      allow update: if isChurchOwner(churchId) ||
        (
          belongsToChurch(churchId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["memberCount", "updatedAt"])
        );

      allow delete: if isChurchOwner(churchId);

      match /members/{memberId} {
        allow read: if belongsToChurch(churchId) || isChurchOwner(churchId);

        allow create: if isSignedIn() &&
          request.auth.uid == memberId &&
          request.resource.data.uid == request.auth.uid;

        allow update: if (
            belongsToChurch(churchId) &&
            request.auth.uid == memberId
          ) || isChurchOwner(churchId);

        allow delete: if isChurchOwner(churchId) ||
          (belongsToChurch(churchId) && request.auth.uid == memberId);
      }

      match /events/{eventId} {
        allow read: if belongsToChurch(churchId);
        allow create, update, delete: if isChurchOwner(churchId);
      }

      match /chatMessages/{messageId} {
        allow read: if belongsToChurch(churchId);

        allow create: if belongsToChurch(churchId) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.churchId == churchId;

        allow update, delete: if isChurchOwner(churchId) ||
          (belongsToChurch(churchId) && resource.data.senderId == request.auth.uid);
      }

      match /chat/{messageId} {
        allow read: if belongsToChurch(churchId);

        allow create: if belongsToChurch(churchId) &&
          request.resource.data.uid == request.auth.uid;

        allow update, delete: if isChurchOwner(churchId) ||
          (belongsToChurch(churchId) && resource.data.uid == request.auth.uid);
      }

      match /prayerRequests/{requestId} {
        allow read: if belongsToChurch(churchId) || isChurchOwner(churchId);

        allow create: if belongsToChurch(churchId) &&
          request.resource.data.churchId == churchId &&
          (
            request.resource.data.uid == request.auth.uid ||
            request.resource.data.userId == request.auth.uid ||
            request.resource.data.authorId == request.auth.uid
          );

        allow update: if isChurchOwner(churchId) ||
          (
            belongsToChurch(churchId) &&
            (
              resource.data.uid == request.auth.uid ||
              resource.data.userId == request.auth.uid ||
              resource.data.authorId == request.auth.uid
            )
          );

        allow delete: if isChurchOwner(churchId) ||
          (
            belongsToChurch(churchId) &&
            (
              resource.data.uid == request.auth.uid ||
              resource.data.userId == request.auth.uid ||
              resource.data.authorId == request.auth.uid
            )
          );
      }

      match /newGuests/{guestId} {
        allow read: if isChurchOwner(churchId) || isSuperAdmin();

        allow create: if (
            isSignedIn() &&
            request.resource.data.churchId == churchId
          ) || (
            request.auth == null &&
            request.resource.data.churchId == churchId
          );

        allow update, delete: if isChurchOwner(churchId) || isSuperAdmin();
      }

      match /testimonies/{testimonyId} {
        allow read: if belongsToChurch(churchId) || isChurchOwner(churchId);

        allow create: if belongsToChurch(churchId) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.churchId == churchId &&
          (
            request.resource.data.status == "PENDING" ||
            request.resource.data.status == "APPROVED"
          );

        allow update: if
          isChurchOwner(churchId) ||
          (
            belongsToChurch(churchId) &&
            resource.data.authorId == request.auth.uid &&
            request.resource.data.authorId == resource.data.authorId &&
            request.resource.data.churchId == resource.data.churchId
          );

        allow delete: if isChurchOwner(churchId) ||
          (belongsToChurch(churchId) && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow read: if belongsToChurch(churchId) || isChurchOwner(churchId);

          allow create: if belongsToChurch(churchId) &&
            request.resource.data.uid == request.auth.uid &&
            request.resource.data.churchId == churchId &&
            request.resource.data.testimonyId == testimonyId;

          allow update, delete: if isChurchOwner(churchId) ||
            (belongsToChurch(churchId) && resource.data.uid == request.auth.uid);
        }
      }
    }

    match /analytics/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSuperAdmin();
    }
  }
}