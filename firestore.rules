// firestore.rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function sameChurch(churchId) {
      return signedIn() && userDoc().data.churchId == churchId;
    }

    function isAdmin(churchId) {
      return signedIn()
        && userDoc().data.churchId == churchId
        && userDoc().data.role in ['ADMIN', 'LEADER'];
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /churches/{churchId} {
      allow read: if sameChurch(churchId);
      allow create: if signedIn();
      allow update: if isAdmin(churchId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if sameChurch(churchId);
        allow create: if signedIn() && request.auth.uid == memberId;
        allow update: if isAdmin(churchId);
        allow delete: if isAdmin(churchId);
      }

      match /announcements/{announcementId} {
        allow read: if sameChurch(churchId);
        allow create, update, delete: if isAdmin(churchId);
      }
    }
  }
}